{
  "manifest_version": 3,
  "name": "Background Opacity Controller",
  "description": "Webページの背景だけ透過度を調整します",
  "version": "1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "背景透過コントローラー"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
